# ── 복사해서 .env 로 저장하고 값 채우기 (.env 는 git 에 안 올라감) ──

# 1) Claude 요약용 (필수)
ANTHROPIC_API_KEY=sk-ant-여기에_키
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 2) 다운로드 폴더 (셀레니움이 보따리\YYMMDD 로 저장하는 루트)
#    비워두면 기본값 = report_pipeline\보따리 (download_reports.py 와 동일 위치)
# DOWNLOAD_ROOT=C:\Users\USER\OneDrive\문서\QAE-dashboard\report_pipeline\보따리

# 3) reports.json 위치 (보통 그대로 두면 됨)
# REPORTS_JSON=C:\Users\USER\OneDrive\문서\QAE-dashboard\macro_hub\public\data\reports.json

# 4) PDF 저장소: 처음엔 local 로 테스트 → 잘 되면 r2 로 변경
STORAGE=local

# 5) STORAGE=r2 일 때만 채우기 (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=research-reports
# R2 버킷을 Public 으로 열고 받은 공개 도메인 (예: https://pub-xxxxx.r2.dev)
R2_PUBLIC_BASE=

# BofA 로그인 폴백 (선택; 보통은 브라우저 세션 로그인으로 충분)
BOFA_USERID=your_bofa_id
BOFA_PASSWORD=your_bofa_password
